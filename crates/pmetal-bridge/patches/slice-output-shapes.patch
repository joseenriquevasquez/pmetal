   return (axes_ == s_other.axes_ && slice_size_ == s_other.slice_size_);
 }
 
+std::vector<Shape> Slice::output_shapes(const std::vector<array>&) {
+  // Compute output shape from start/end/strides (all constant in the primitive)
+  Shape out_shape;
+  out_shape.reserve(start_indices_.size());
+  for (size_t i = 0; i < start_indices_.size(); ++i) {
+    auto start = start_indices_[i];
+    auto end = end_indices_[i];
+    auto stride = strides_[i];
+    // ceil_div(end - start, stride)
+    auto extent = (end - start + stride - 1) / stride;
+    out_shape.push_back(extent);
+  }
+  return {out_shape};
+}
+
 std::vector<Shape> DynamicSlice::output_shapes(const std::vector<array>&) {
   return {slice_size_};
 }
